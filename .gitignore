# Rust
/target
**/*.rs.bk
Cargo.lock.bak

# IDE / editor
/.idea
/.vscode/*
!/.vscode/settings.json.example
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Local environment
.env
.env.local
*.local

# Build artifacts (cross-platform packaging -- see spec section 10)
/dist
/release
*.deb
*.rpm
*.pkg
*.msi
*.msix
*.AppImage
*.tar.zst

# Bundled data (generated, not source-controlled)
/var/
/data/

# Runtime metadata stores created by `computeza serve --state-db`.
# Default file lives next to wherever the user ran the server from;
# don't track any of them.
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite-wal
*.sqlite-shm

# Misc
*.log
*.pid
.cache/
.claude/
